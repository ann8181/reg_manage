{
    "categories": {
        "email": {
            "name": "邮箱任务",
            "description": "临时邮箱和真实邮箱注册服务",
            "enabled": true,
            "groups": {
                "temp_email": {
                    "name": "临时邮箱 API",
                    "description": "无需注册的临时邮箱服务",
                    "enabled": true,
                    "tasks": {
                        "email.mailtm": {
                            "name": "Mail.tm API",
                            "description": "Mail.tm 临时邮箱 API",
                            "enabled": false,
                            "module": "tasks.email.mailtm",
                            "class": "MailTmProvider",
                            "results_dir": "results/mailtm"
                        },
                        "email.guerrillamail": {
                            "name": "GuerrillaMail API",
                            "description": "GuerrillaMail 临时邮箱 API",
                            "enabled": false,
                            "module": "tasks.email.guerrillamail",
                            "class": "GuerrillaMailProvider",
                            "results_dir": "results/guerrillamail"
                        },
                        "email.getnada": {
                            "name": "GetNada API",
                            "description": "GetNada 临时邮箱 API",
                            "enabled": false,
                            "module": "tasks.email.getnada",
                            "class": "GetNadaProvider",
                            "results_dir": "results/getnada"
                        },
                        "email.yopmail": {
                            "name": "YopMail API",
                            "description": "YopMail 临时邮箱 API (仅收取)",
                            "enabled": false,
                            "module": "tasks.email.yopmail",
                            "class": "YopMailProvider",
                            "results_dir": "results/yopmail"
                        }
                    }
                },
                "real_email": {
                    "name": "真实邮箱注册",
                    "description": "需要真实注册的邮箱服务",
                    "enabled": true,
                    "tasks": {
                        "email.outlook": {
                            "name": "Outlook 注册",
                            "description": "微软 Outlook 邮箱注册 + 邮件收取",
                            "enabled": true,
                            "module": "tasks.email.outlook",
                            "class": "OutlookRegister",
                            "results_dir": "results/outlook"
                        },
                        "email.gmail": {
                            "name": "Gmail 邮件收取",
                            "description": "Gmail IMAP 邮件收取",
                            "enabled": false,
                            "module": "tasks.email.gmail",
                            "class": "GmailClient",
                            "results_dir": "results/gmail"
                        }
                    }
                },
                "temp_convert": {
                    "name": "临时邮箱转换",
                    "description": "将临时邮箱转换为 API 版本",
                    "enabled": true,
                    "tasks": {
                        "email.tempmail": {
                            "name": "TempMail 转换",
                            "description": "Web 临时邮箱转 API 版本",
                            "enabled": false,
                            "module": "tasks.email.tempmail",
                            "class": "TempMailConverter",
                            "results_dir": "results/tempmail"
                        }
                    }
                }
            }
        },
